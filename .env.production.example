# CycleIQ production environment — copy values into Vercel + Render dashboards.
# Canonical site: https://cycleiq.xyz
# API (Render): https://cycleiq-sbze.onrender.com

# =============================================================================
# Vercel — apps/web project
# =============================================================================
# Production (cycleiq.xyz):
NEXT_PUBLIC_SITE_URL=https://cycleiq.xyz
NEXT_PUBLIC_API_URL=https://cycleiq-sbze.onrender.com
# Preview deploys (*.vercel.app): use same-origin proxy (avoids CORS to Render).
# Set for Preview environment in Vercel dashboard:
#   NEXT_PUBLIC_API_PROXY=1
#   API_BACKEND_URL=https://cycleiq-dev.onrender.com
# (Do not set NEXT_PUBLIC_API_URL on Preview when using the proxy.)
NEXT_PUBLIC_SUPPORT_EMAIL=support@cycleiq.xyz
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# =============================================================================
# Render — cycleiq-api service (see render.yaml)
# =============================================================================
FLASK_ENV=production
FRONTEND_URL=https://cycleiq.xyz
# Optional: comma-separated extra browser origins (e.g. Vercel preview URLs)
# CORS_EXTRA_ORIGINS=https://cycleiq-git-main-yourteam.vercel.app

# Supabase → Settings → API
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# Supabase → Settings → Database
# Direct connection (port 5432) — Alembic migrations / preDeployCommand only
DATABASE_URL=postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres
# Pooling connection (port 6543) — Flask runtime queries
DATABASE_POOL_URL=postgresql://postgres:<password>@db.<project-id>.supabase.co:6543/postgres?pgbouncer=true

# Stripe
STRIPE_SECRET_KEY=rk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# =============================================================================
# External dashboards (not env vars — configure manually)
# =============================================================================
#
# Supabase → Authentication → URL Configuration (configure BOTH projects if using dev + prod)
#
# Production Supabase:
#   Site URL:              https://cycleiq.xyz
#   Redirect URLs:         https://cycleiq.xyz/**
#                          https://cycleiq.xyz/auth/callback
#
# Dev / Preview Supabase (Vercel Preview env uses this project):
#   Site URL:              http://localhost:3000
#   Redirect URLs:         http://localhost:3000/**
#                          https://*-.vercel.app/**     ← official Vercel wildcard (NOT *.vercel.app)
#   Optional exact URL:    https://your-branch-xxx.vercel.app/auth/callback
#
# Vercel env scope:
#   NEXT_PUBLIC_SITE_URL — set for **Production only** (cycleiq.xyz).
#   Do NOT set it on Preview; OAuth uses the preview host automatically.
#
# Stripe → Developers → Webhooks
#   Endpoint URL:          https://cycleiq-sbze.onrender.com/webhooks/stripe
#   Events:                checkout.session.completed,
#                          customer.subscription.created/updated/deleted
#
# Render → cycleiq-api service URL (optional custom domain later: api.cycleiq.xyz)
#   https://cycleiq-sbze.onrender.com
#
# Vercel → Project → Settings → Domains
#   cycleiq.xyz, www.cycleiq.xyz (www redirects to apex via vercel.json)
