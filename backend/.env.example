# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Supabase project credentials
# Get these from: Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Auth JWT secret – used by Flask to verify Supabase Auth tokens.
# Get this from: Supabase Dashboard -> Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# PostgreSQL direct connection (SQLAlchemy / Alembic)
# Get this from: Supabase Dashboard -> Settings -> Database
# Use the "Connection pooling" URI (port 6543) for Flask in production
# Use the direct URI (port 5432) for Alembic migrations
DATABASE_URL=postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres
DATABASE_POOL_URL=postgresql://postgres:<password>@db.<project-id>.supabase.co:6543/postgres?pgbouncer=true

# Stripe (test mode first; use Restricted Key rk_test_... in production code)
# Dashboard -> Developers -> API keys -> Create restricted key
STRIPE_SECRET_KEY=rk_test_...
# Dashboard -> Developers -> Webhooks -> endpoint signing secret (or `stripe listen` locally)
STRIPE_WEBHOOK_SECRET=whsec_...
# Product catalog -> CycleIQ Premium -> monthly price id
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
# Frontend origin for Checkout success/cancel URLs (no trailing slash)
# Local: http://localhost:3000 | Prod: https://cycleiq.xyz
FRONTEND_URL=http://localhost:3000
# Optional extra CORS origins (comma-separated), e.g. Vercel preview deploys
# CORS_EXTRA_ORIGINS=
