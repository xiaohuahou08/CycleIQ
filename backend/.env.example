# Flask Backend Environment Variables
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=change-me-to-a-random-secret
PORT=5000

# Database (Render will set DATABASE_URL automatically for managed PostgreSQL)
# For local dev, use your Supabase connection string:
#   DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DATABASE_URL=

# Optional: direct Supabase credentials (for auth validation)
SUPABASE_URL=
SUPABASE_ANON_KEY=
