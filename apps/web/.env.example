# CycleIQ web app — copy to apps/web/.env.local for local development.
# Production values go in the Vercel project dashboard (see /.env.production.example).

# Flask API (local: http://localhost:5000 | prod: https://cycleiq-sbze.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Supabase → Settings → API → Project URL (origin only, no /auth/v1/... path)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SEO / legal (prod: https://cycleiq.xyz)
# Set NEXT_PUBLIC_SITE_URL in Vercel **Production only** — not Preview (OAuth uses preview host).
# NEXT_PUBLIC_SITE_URL=https://cycleiq.xyz
# NEXT_PUBLIC_SUPPORT_EMAIL=support@cycleiq.xyz

# Contact form (server-only — Vercel env, not NEXT_PUBLIC_*)
# RESEND_API_KEY=re_...
# CONTACT_TO_EMAIL=you@example.com
# CONTACT_FROM_EMAIL=CycleIQ <noreply@cycleiq.xyz>

# Google AdSense: verification meta is always on (layout.tsx). Set both when ready to load ads.
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-8772060670873398
# NEXT_PUBLIC_ADSENSE_SLOT=<ad-unit-slot-id-from-adsense-dashboard>

# Vercel Preview: same-origin proxy to dev Render (see /.env.production.example)
# NEXT_PUBLIC_API_PROXY=1
# API_BACKEND_URL=https://cycleiq-dev.onrender.com
