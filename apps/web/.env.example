# CycleIQ web app — copy to apps/web/.env.local for local development.
# Production values go in the Vercel project dashboard (see /.env.production.example).

# Flask API (local: http://localhost:5000 | prod: https://cycleiq-sbze.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SEO / legal (prod: https://cycleiq.xyz)
# NEXT_PUBLIC_SITE_URL=https://cycleiq.xyz
# NEXT_PUBLIC_SUPPORT_EMAIL=support@cycleiq.xyz

# Google AdSense publisher ID (from adsense.google.com). Leave unset to disable ads.
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Vercel Preview: same-origin proxy to dev Render (see /.env.production.example)
# NEXT_PUBLIC_API_PROXY=1
# API_BACKEND_URL=https://cycleiq-dev.onrender.com
